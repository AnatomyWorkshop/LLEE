# LLEE API Configuration
# Copy this file to .env and fill in your keys
# NEVER commit .env to git

# ─── GLM-4.5 (ZhipuAI) ──────────────────────────────────────────────────────
GLM_API_KEY=your-glm-key-here
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
GLM_MODEL=glm-4.5-air

# ─── DeepSeek Reasoner ───────────────────────────────────────────────────────
DEEPSEEK_API_KEY=your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-reasoner

# ─── Claude Opus (via relay) ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-claude-key-here
ANTHROPIC_BASE_URL=https://lanyiapi.com
ANTHROPIC_MODEL=claude-opus-4-6-thinking

# ─── Doubao Seed (Volcengine) ────────────────────────────────────────────────
DOUBAO_API_KEY=your-doubao-key-here
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/responses
DOUBAO_MODEL=doubao-seed-2-0-pro-260215
